<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- WebView Container -->
    <FrameLayout
        android:id="@+id/webviewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="56dp" />

    <!-- New Tab Page -->
    <LinearLayout
        android:id="@+id/newTabPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_primary"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Onyx Browser"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by Blackbox Intel Group"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/ntpSearchInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/search_bg"
            android:hint="Search or enter URL"
            android:textColorHint="@color/text_dim"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="20dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="textUri"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Top Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_secondary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:elevation="4dp"
        android:layout_gravity="top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="@color/text_secondary"
            android:scaleType="centerInside"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Forward"
            android:tint="@color/text_secondary"
            android:scaleType="centerInside"
            android:padding="6dp" />

        <ImageView
            android:id="@+id/securityIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/text_dim"
            android:layout_marginStart="4dp" />

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/url_bar_bg"
            android:hint="Search or enter URL"
            android:textColorHint="@color/text_dim"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:paddingHorizontal="12dp"
            android:layout_marginHorizontal="6dp" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:tint="@color/text_secondary"
            android:scaleType="centerInside"
            android:padding="6dp" />

    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@android:color/transparent"
        android:max="100"
        android:visibility="gone" />

    <!-- Find in Page Bar -->
    <LinearLayout
        android:id="@+id/findBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:elevation="6dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/findInput"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/url_bar_bg"
            android:hint="Find in page"
            android:textColorHint="@color/text_dim"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:singleLine="true"
            android:paddingHorizontal="12dp"
            android:imeOptions="actionSearch" />

        <ImageButton
            android:id="@+id/btnFindPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Previous" />

        <ImageButton
            android:id="@+id/btnFindNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Next" />

        <ImageButton
            android:id="@+id/btnFindClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_secondary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Home"
            android:tint="@color/text_secondary"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/btnTabs"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_counter_bg"
            android:layout_marginHorizontal="16dp" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:tint="@color/text_secondary"
            android:scaleType="centerInside" />

    </LinearLayout>

</FrameLayout>
